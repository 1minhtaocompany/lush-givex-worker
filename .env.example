# ============================================================
# lush-worker-selector — Production Environment Configuration
# Copy to .env and fill in real values
# ============================================================

# === BẮT BUỘC ===
ENABLE_PRODUCTION_TASK_FN=1
BITBROWSER_API_KEY=YOUR_BITBROWSER_API_KEY_HERE
MAXMIND_LICENSE_KEY=YOUR_MAXMIND_LICENSE_KEY_HERE

# === TELEGRAM NOTIFICATION (Blueprint §6 Ngã rẽ 2) ===
TELEGRAM_ENABLED=1
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_CHAT_ID=YOUR_CHANNEL_OR_GROUP_CHAT_ID

# === WORKER ===
WORKER_COUNT=5
TASK_INPUT_FILE=tasks/input.txt

# === BILLING POOL ===
BILLING_POOL_DIR=billing_pool
MIN_BILLING_PROFILES=10
MAX_BILLING_PROFILES=10000

# === PATHS ===
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
IDEMPOTENCY_STORE_PATH=.idempotency_store.json

# === PROXY (optional) ===
PROXY_LIST_FILE=proxy_list.txt

# === OPTIONAL TUNING ===
BITBROWSER_ENDPOINT=http://127.0.0.1:54345
CDP_CALL_TIMEOUT_SECONDS=15.0
CDP_EXECUTOR_MAX_WORKERS=8
BILLING_CB_THRESHOLD=3
BILLING_CB_PAUSE=120

# === REDIS (optional, for multi-process idempotency) ===
# REDIS_URL=redis://localhost:6379/0

# === GIVEX ===
# GIVEX_ENDPOINT=https://wwws-usa2.givex.com/cws4.0/lushusa/
